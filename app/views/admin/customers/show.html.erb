<div class="row g-4">
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <h3 class="mb-1"><%= @customer.name %></h3>
        <p class="text-muted mb-4">Perfil do cliente</p>

        <div class="info-row">
          <span>Telefone</span>
          <strong><%= @customer.phone %></strong>
        </div>
        <div class="info-row">
          <span>Email</span>
          <strong><%= @customer.email.presence || "-" %></strong>
        </div>
        <div class="info-row">
          <span>Bairro</span>
          <strong><%= @customer.neighborhood.presence || "-" %></strong>
        </div>
        <div class="info-row">
          <span>Endereco</span>
          <strong><%= @customer.address.presence || "-" %></strong>
        </div>
        <div class="info-row">
          <span>Total de pedidos</span>
          <strong><%= @customer.total_orders %></strong>
        </div>
        <div class="info-row">
          <span>Total faturado</span>
          <strong><%= number_to_currency(@customer.total_spent) %></strong>
        </div>

        <% if @customer.notes.present? %>
          <hr>
          <h6>Observacoes</h6>
          <p class="mb-0 text-muted"><%= @customer.notes %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h4 class="mb-0">Pedidos do cliente</h4>
          <%= link_to "Voltar", admin_customers_path, class: "btn btn-sm btn-outline-secondary" %>
        </div>

        <% if @orders.any? %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead>
                <tr>
                  <th>Codigo</th>
                  <th>Status</th>
                  <th>Tipo</th>
                  <th>Total</th>
                  <th>Data</th>
                </tr>
              </thead>
              <tbody>
                <% @orders.each do |order| %>
                  <tr>
                    <td><%= link_to order.code, admin_order_path(order), class: "text-decoration-none" %></td>
                    <td><span class="badge text-bg-<%= order.status_badge_class %>"><%= order.status_label %></span></td>
                    <td><%= order.fulfillment_type_label %></td>
                    <td><%= number_to_currency(order.total_amount) %></td>
                    <td><%= l(order.created_at, format: :short) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-muted mb-0">Esse cliente ainda nao possui pedidos cadastrados.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
