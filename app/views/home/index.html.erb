<div class="container mt-4 mb-5">
  <section class="hero-925 hero-cake mb-4">
    <div>
      <p class="hero-kicker mb-1">Receitas artesanais, cobertura cremosa e muito carinho</p>
      <h1 class="hero-title mb-2">Bolos de cenoura para o cafe da tarde, encomendas e festas</h1>
      <p class="hero-subtitle mb-0">Escolha seus sabores, monte o pedido e fale com a Casa do bolo de cenoura pelo WhatsApp em poucos minutos.</p>
    </div>
    <a href="https://wa.me/5569981042225" target="_blank" rel="noopener" class="btn btn-success btn-sm">
      Chamar no WhatsApp
      <i class="bi bi-whatsapp ms-2"></i>
    </a>
  </section>

  <% if @featured_products.any? %>
    <section class="row mb-4">
      <% @featured_products.each do |product| %>
        <div class="col-12 col-lg-4 mb-3">
          <div class="featured-product-card h-100">
            <span class="badge rounded-pill text-bg-warning mb-3">Mais pedido</span>
            <h5><%= product.title %></h5>
            <p class="text-muted mb-3"><%= truncate(product.description, length: 100) %></p>
            <div class="d-flex justify-content-between align-items-center">
              <strong><%= number_to_currency(product.price) %></strong>
              <%= link_to "Ver bolo", product_path(product), class: "btn btn-sm btn-outline-dark" %>
            </div>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>

  <div class="row">
    <div class="col-12 col-lg-4 col-xxl-3 mb-4 mx-auto">
      <%= search_form_for @q, url: root_path, method: :get do |f| %>
        <label for="search_product" class="form-label fw-semibold">Buscar bolos</label>
      <div class="input-group search-joias-group">
          <%= f.search_field :title_cont, class: 'form-control', placeholder: 'Ex: bolo com cobertura de chocolate', value: params.dig(:q, :title_cont) %>
        <button type="submit" class="btn btn-primary search-joias-btn">
          <i class="bi bi-search me-1"></i>
          <span>Buscar bolos</span>
        </button>
      </div>
      <div class="mt-3 col-md-12">
        <label for="search_product" class="form-label">Ordenar por preco: </label>
        <%= f.select :s, [['Mais Baixo', 'price asc'], ['Mais Alto', 'price desc']], { include_blank: 'Selecione a ordem' }, { class: 'form-select', onchange: 'this.form.submit()' } %>
      </div>
      <% end %>
      <div class="sidebar mt-4 card p-3 shadow-sm border-0">
        <section>
          <h5 class="mb-3">Categorias</h5>
          <% Category.all.each do |category| %>
          <%= link_to "#{category.description} (#{category.products.size})", root_path(q: { category_id_eq: category.id }), class: 'link-secondary d-block py-1' %>
          <% end %>
        </section>
      </div>
    </div>

    <div class="col-12 col-lg-8 col-xxl-9">
      <div class="row mb-3 align-items-center">
        <div class="col-12">
          <span class="d-block result-count"><%= "Mostrando #{@products.present? ? "1" : "0"}-#{@products&.size} de #{@pagy&.count} produtos" %></span>
        </div>
      </div>
      <div class="row">
        <% @products.each do |product| %>
        <div class="col-12 col-sm-6 col-md-4 col-lg-6 col-xl-4 mb-3">
          <div class="card card-image-product">
            <%= link_to product_path(product) do %>
            <%= image_tag set_image_product_or_ilustration_src(product), alt: "Minha Imagem", class: 'card-img-top' %>
            <% end %>
            <div class="card-body pt-3 p-4">
              <h6 class="fs-4 product-title-card"><%= product.title %></h6>
              <div class="product-meta-row mb-3">
                <span class="product-price-highlight">
                  <%= number_to_currency(product.price, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
                </span>
                <span class="product-stock-pill <%= product.stock_quantity <= 3 ? 'product-stock-pill-low' : '' %>">
                  <i class="bi bi-basket2 me-1"></i>
                  <%= product.stock_quantity %> disponiveis
                </span>
              </div>
              <div class="product-card-footer">
                <%= link_to "Ver detalhes", product_path(product), class: "btn btn-sm btn-outline-secondary product-secondary-btn" %>
                <button onclick="adicionarAoCarrinho(<%= product.id %>, '<%= j(product.title) %>', <%= product.price %>)" class="btn btn-sm cake-action-btn">
                  <i class="bi bi-bag-plus me-1"></i>
                  Adicionar
                </button>
              </div>
            </div>
          </div>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
